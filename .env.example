# OpenMythos — 環境変数テンプレート
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# .env は .gitignore に含まれており、コミットされません。

# ============================================================
# セキュリティ設定
# ============================================================

# APIキー (Bearer Token認証)
# 未設定の場合は認証なし (開発モードのみ許容)
API_KEY=

# 複数キーを許可する場合はコンマ区切りで列挙
# API_KEYS=key1,key2,key3

# ============================================================
# モデル設定
# ============================================================

# 実行デバイス: cpu / cuda
DEVICE=cpu

# デフォルトのループ回数 (推論深度)
DEFAULT_LOOPS=4

# 最大ループ回数の上限
MAX_LOOPS=16

# モデルの埋め込み次元 (開発用: 256, 本番用: 2048以上)
MODEL_DIM=256

# Attentionの種類: gqa / mla
MODEL_ATTN=gqa

# Tokenizerの名前 (HuggingFace Hub のモデルID)
TOKENIZER_NAME=gpt2

# 学習済みチェックポイントのパス (未設定でランダム初期化)
MODEL_CHECKPOINT=

# ============================================================
# サーバー設定
# ============================================================

# Gunicorn ワーカー数 (CPU数 x 2 + 1 が推奨)
WORKERS=2

# 最大生成トークン数
MAX_NEW_TOKENS=256

# 生成温度 (0.0=決定論的, 1.0=ランダム)
TEMPERATURE=1.0

# Top-K サンプリング
TOP_K=50

# Top-P (nucleus) サンプリング
TOP_P=0.95

# ============================================================
# レートリミット設定
# ============================================================

# 1分あたりの最大リクエスト数 (IPアドレスごと)
RATE_LIMIT_RPM=60

# ============================================================
# Cloud Run 設定 (GCPにデプロイする場合のみ)
# ============================================================

GCP_PROJECT=
GCP_REGION=asia-northeast1
IMAGE_TAG=v0.57.0
SERVICE_NAME=openmythos-serve

CLOUD_RUN_MEMORY=4Gi
CLOUD_RUN_CPU=2
CLOUD_RUN_CONCURRENCY=10
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=3
